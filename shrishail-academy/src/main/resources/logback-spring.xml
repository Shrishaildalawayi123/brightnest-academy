<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ============================================= -->
    <!-- BrightNest Academy - Structured Logging       -->
    <!-- JSON in production, readable in development   -->
    <!-- ============================================= -->

    <!-- Dev profile: human-readable console output -->
    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.shrishailacademy" level="INFO"/>
        <logger name="org.springframework.security" level="WARN"/>
    </springProfile>

    <!-- Production profile: structured JSON logging -->
    <springProfile name="prod">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>{"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}","level":"%level","logger":"%logger{36}","thread":"%thread","message":"%replace(%msg){'(password|secret|token|credential|jwt|authorization)[=:\"\\s]*[^,\"\\s}]*','$1=***REDACTED***'}","exception":"%replace(%xException{10}){'(password|secret|token|credential|jwt|authorization)[=:\"\\s]*[^,\"\\s}]*','$1=***REDACTED***'}"}%n</pattern>
            </encoder>
        </appender>

        <!-- Rolling file appender for persistent logs -->
        <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/brightnest-academy.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/brightnest-academy.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>{"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}","level":"%level","logger":"%logger{36}","thread":"%thread","message":"%replace(%msg){'(password|secret|token|credential|jwt|authorization)[=:\"\\s]*[^,\"\\s}]*','$1=***REDACTED***'}","exception":"%replace(%xException{10}){'(password|secret|token|credential|jwt|authorization)[=:\"\\s]*[^,\"\\s}]*','$1=***REDACTED***'}"}%n</pattern>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="JSON_FILE"/>
        </root>

        <logger name="com.shrishailacademy" level="INFO"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
    </springProfile>

</configuration>
