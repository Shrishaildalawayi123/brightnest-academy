# =============================================================
# .env.example — BrightNest Academy
#
# LOCAL DEV: copy to .env, set SPRING_PROFILES_ACTIVE=dev
# PRODUCTION (AWS): copy to /opt/brightnest/.env on EC2,
#                   set SPRING_PROFILES_ACTIVE=prod
# NEVER commit .env to git — it contains secrets!
# =============================================================

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=shrishail_academy
DB_USER=root
DB_PASS=root
DB_USE_SSL=false

# JWT (generate a strong random string, min 64 chars)
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARACTERS_LONG_12345
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000
JWT_REFRESH_PEPPER=CHANGE_ME_REFRESH_PEPPER

# Admin account (change password before first production run)
ADMIN_EMAIL=admin@brightnest-academy.com
ADMIN_PASSWORD=CHANGE_ME_Strong!Pass123

# Hibernate DDL (use 'validate' in production, 'update' in dev)
JPA_DDL_AUTO=update

# Profile
SPRING_PROFILES_ACTIVE=dev

# Server
PORT=8080

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://brightnest-academy.com,https://www.brightnest-academy.com

# Rate Limiting
RATE_LIMIT_BACKEND=inmemory
RATE_LIMIT_API=100
RATE_LIMIT_API_WINDOW=60
RATE_LIMIT_LOGIN=5
RATE_LIMIT_WINDOW=60
RATE_LIMIT_TRUST_FORWARD_HEADERS=false

# Redis (set when using RATE_LIMIT_BACKEND=redis)
# Local dev: keep localhost / inmemory
# AWS production: use your ElastiCache endpoint
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_TIMEOUT=60000

# HikariCP connection pool (optional — defaults work for t3.medium)
HIKARI_MAX_POOL=15
HIKARI_MIN_IDLE=5

# Cookie / HTTPS
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
HTTPS_REQUIRED=false

# WhatsApp (optional)
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_SENDER=

# HikariCP Connection Pool
HIKARI_MAX_POOL=10
HIKARI_MIN_IDLE=5
